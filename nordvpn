#!/bin/bash

set -e

# === Variables ===
NS="vpnspace"
HOST_IF="host-veth"
NS_IF="ns-veth"
SUBNET="10.200.1.0/24"
HOST_IP="10.200.1.1"
NS_IP="10.200.1.2"

# === Determine External Interface ===
EXT_IF=$(ip route show default | awk '/default/ {print $5; exit}')
if [ -z "$EXT_IF" ]; then
  echo "Error: Could not determine external interface."
  exit 1
fi

# === Create Network Namespace ===
if ! sudo ip netns list | grep -q "$NS"; then
  sudo ip netns add "$NS"
fi

# === Create and Configure veth Pair ===
if ! sudo ip link show "$HOST_IF" &>/dev/null; then
  sudo ip link add "$HOST_IF" type veth peer name "$NS_IF"
fi

if ! sudo ip netns exec "$NS" ip link show "$NS_IF" &>/dev/null; then
  sudo ip link set "$NS_IF" netns "$NS"
fi

# === Configure IP Addresses ===
# Host side configuration
sudo ip addr add "$HOST_IP/24" dev "$HOST_IF" 2>/dev/null || true
sudo ip link set "$HOST_IF" up

# Namespace side configuration
sudo ip netns exec "$NS" ip addr add "$NS_IP/24" dev "$NS_IF" 2>/dev/null || true
sudo ip netns exec "$NS" ip link set "$NS_IF" up
sudo ip netns exec "$NS" ip link set lo up

# === Add Routes in Namespace ===
sudo ip netns exec "$NS" ip route add "$SUBNET" dev "$NS_IF" 2>/dev/null || true
sudo ip netns exec "$NS" ip route add default via "$HOST_IP" dev "$NS_IF" 2>/dev/null || true

# === Enable IP Forwarding ===
sudo sysctl -w net.ipv4.ip_forward=1 >/dev/null

# === Set Up NAT with iptables ===
sudo iptables -t nat -C POSTROUTING -s "$SUBNET" -o "$EXT_IF" -j MASQUERADE 2>/dev/null || \
sudo iptables -t nat -A POSTROUTING -s "$SUBNET" -o "$EXT_IF" -j MASQUERADE

# === Configure FORWARD Rules ===
sudo iptables -C FORWARD -i "$EXT_IF" -o "$HOST_IF" -m state --state RELATED,ESTABLISHED -j ACCEPT 2>/dev/null || \
sudo iptables -A FORWARD -i "$EXT_IF" -o "$HOST_IF" -m state --state RELATED,ESTABLISHED -j ACCEPT
sudo iptables -C FORWARD -i "$HOST_IF" -o "$EXT_IF" -j ACCEPT 2>/dev/null || \
sudo iptables -A FORWARD -i "$HOST_IF" -o "$EXT_IF" -j ACCEPT

# === Configure DNS for Namespace ===
sudo mkdir -p /etc/netns/"$NS"
cat <<EOF | sudo tee /etc/netns/"$NS"/resolv.conf >/dev/null
nameserver 8.8.8.8
nameserver 8.8.4.4
EOF

# === Fetch NordVPN Server List ===
response=$(curl -s "https://api.nordvpn.com/v1/servers?limit=0")
if [[ -z "$response" ]]; then
    echo "Failed to fetch NordVPN server data."
    exit 1
fi

# === Find the Best OpenVPN TCP Server ===
search_country="$1"
best_server=$(echo "$response" | jq -r --arg country "$search_country" '
    .[] | 
    select(.technologies[]?.pivot.technology_id == 3 and .status == "online") | 
    {name: .name, hostname: .hostname, load: .load, country: .locations[0].country.name} |
    select((.country | test($country; "i")) or ($country == "")) |
    @base64' | sort -t "|" -k3,3n | head -n1)

if [[ -z "$best_server" ]]; then
    echo "No OpenVPN TCP servers found."
    exit 1
fi

# === Extract Best Server Details ===
best_server_json=$(echo "$best_server" | base64 --decode | jq -r '.')
server_name=$(echo "$best_server_json" | jq -r '.name')
server_country=$(echo "$best_server_json" | jq -r '.country')
server_load=$(echo "$best_server_json" | jq -r '.load')
server_hostname=$(echo "$best_server_json" | jq -r '.hostname')

# Print best server details
echo "Best OpenVPN TCP Server:"
echo "Name: $server_name"
echo "Country: $server_country"
echo "Load: $server_load%"
echo "Hostname: $server_hostname"

# === Download OpenVPN Configuration File ===
ovpn_file="nordvpn.tcp.ovpn"
ovpn_url="https://downloads.nordcdn.com/configs/files/ovpn_tcp/servers/${server_hostname}.tcp.ovpn"
curl -s -o "$ovpn_file" "$ovpn_url"
if [[ ! -s "$ovpn_file" ]]; then
    echo "Failed to download .ovpn file."
    exit 1
fi

# === Start OpenVPN in Namespace ===
VPN_UUID=$(uuidgen)
VPN_PID_FILE="/tmp/openvpn-${VPN_UUID}.pid"
VPN_LOG_FILE="/tmp/openvpn-${VPN_UUID}.log"
sudo ip netns exec "$NS" openvpn \
    --config nordvpn.tcp.ovpn \
    --auth-user-pass nordvpn.auth \
    --daemon \
    --log "$VPN_LOG_FILE" \
    --writepid "$VPN_PID_FILE"

if [[ ! -f "$VPN_PID_FILE" ]]; then
    sudo cat "$VPN_LOG_FILE"  # Debugging log
    exit 1
fi
VPN_PID=$(cat "$VPN_PID_FILE")

# Ensure cleanup on exit
cleanup() {
    sudo kill -9 "$VPN_PID"
}
trap cleanup EXIT SIGINT SIGTERM

# Wait and verify VPN connection
sleep 5
if ! ps -p $VPN_PID > /dev/null; then
    echo -e "\033[31mVPN failed to start\033[0m"
    echo -e "\033[33mOpenVPN log output:\033[0m"
    cat "$VPN_LOG_FILE"  # Debugging log
    exit 1
fi

# Print VPN IP
echo -e "\033[31mIP address: $(sudo ip netns exec "$NS" curl -s https://ipinfo.io/ip)\033[0m"

# Shift and execute the command passed to the script
shift
sudo ip netns exec "$NS" sudo -u $USER -- "$@"
